# Slack — create app at https://api.slack.com/apps using the manifest in README
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# ─── LLM provider ────────────────────────────────────────────────────────
# Pick one provider config block below and uncomment.

# Option A: OpenRouter (recommended — works with Claude, GPT, Llama, Gemini, etc.)
LLM_PROVIDER=openai
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=anthropic/claude-opus-4
# Optional OpenRouter app identification:
# OPENROUTER_REFERER=https://github.com/your-org/sherlock-ops
# OPENROUTER_TITLE=sherlock-ops

# Option B: Anthropic direct
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-7

# Option C: OpenAI direct
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Option D: Any other OpenAI-compatible endpoint (Together, Groq, Ollama, ...)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ─── Authorization ───────────────────────────────────────────────────────
# Comma-separated Slack user IDs allowed to invoke the bot.
# Leave empty to allow everyone in the workspace (not recommended).
ALLOWED_SLACK_USERS=

# ─── Audit log ───────────────────────────────────────────────────────────
# SQLite file path. Created on first run if absent. Defaults to ./sherlock-audit.sqlite
# SHERLOCK_AUDIT_DB=/var/lib/sherlock-ops/audit.sqlite

# ─── Single-host shell allowlist (single-host mode only) ─────────────────
# Comma-separated list of allowed shell command prefixes for the local host.
# Each entry is a prefix that the LLM's command must start with (argv-style match).
# Examples on allowlist will run without approval; everything else requires it.
# LOCAL_SHELL_ALLOWLIST=df -h,free -m,uptime,journalctl -u nginx
