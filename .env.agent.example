# Sherlock agent — runs on each target host (where PM2 lives).
# Dials *out* to the control plane over WebSocket.

# URL of the sherlock-ops control plane WSS endpoint.
#   - Local dev:    ws://localhost:8787/agent
#   - Behind proxy: wss://sherlock.example.com/agent
SHERLOCK_CONTROL_URL=ws://localhost:8787/agent

# Must match an entry in the control plane's hosts.json
SHERLOCK_HOST_ID=api-prod-1
SHERLOCK_AGENT_TOKEN=CHANGE_ME_to_a_long_random_secret
